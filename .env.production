# Build-time config สำหรับ deploy บน POC (https://poc.moph.go.th/emac)
# ค่าเหล่านี้ไม่ลับ (ฝังลง bundle ตอน build) — commit ได้
#
# backend mount ใต้ /emac (nginx pass-through ไม่ strip) → API base = /emac
#   getProviders → /emac/auth/providers
#   listPatients → /emac/api/v1/patients
VITE_API_BASE=/emac

# POC อยู่ใต้ subpath /emac ของ domain แชร์ (poc.moph.go.th) — ไม่ใช่ root
VITE_BASE_PATH=/emac/
VITE_ALLOWED_HOSTS=poc.moph.go.th
